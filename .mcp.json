{
  "mcpServers": {
    "lark-docs": {
      "command": "bunx",
      "args": [
        "--registry=http://bnpm.byted.org/",
        "@byted/mcp-lark-docs-ext@latest"
      ],
      "env": {
        "NPM_CONFIG_REGISTRY": "http://bnpm.byted.org/",
        "AUTH_CALLBACK_PORT": "6688",
        "AUTH_CALLBACK_ENDPOINT": "/lark/callback",
        "LARK_TENANT": "bytedance"
      }
    },
    "tika": {
      "command": "bunx",
      "args": [
        "--registry=http://bnpm.byted.org/",
        "@tiktok-mcp/tika"
      ],
      "env": {
        "NPM_CONFIG_REGISTRY": "http://bnpm.byted.org/",
        "TIKA_ENV": "office"
      }
    },
    "semi-mcp": {
      "command": "bunx",
      "args": [
        "-y",
        "--registry=http://bnpm.byted.org/",
        "@ies/semi-mcp-bytedance"
      ],
      "env": {
        "NPM_CONFIG_REGISTRY": "http://bnpm.byted.org/"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "adk-mobile": {
      "command": "npx",
      "args": [
        "-y",
        "--registry=https://bnpm.byted.org",
        "@byted-tiktok/adk-mobile-mcp@latest",
        "--workflow-dir",
        ".ttadk/.adk-mobile"
      ],
      "env": {
        "platform": "iOS"
      }
    }
  }
}
