# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=auction

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE=86400

# Service Ports
GATEWAY_PORT=:8080
PRODUCT_SERVICE_PORT=:8081
AUCTION_SERVICE_PORT=8082
TEST_SERVICE_URL=http://localhost:18090
TEST_SERVICE_WS_URL=ws://localhost:18092
TEST_GATEWAY_URL=http://localhost:8080

# Environment
ENVIRONMENT=development

# GrowthBook A/B Testing Configuration
GROWTHBOOK_API_HOST=http://localhost:3200
GROWTHBOOK_CLIENT_KEY=dev-client-key
GROWTHBOOK_SECRET_KEY=dev-secret-key
GROWTHBOOK_ENABLED=true

# Nacos Configuration Center
NACOS_SERVER_ADDR=localhost:8848
NACOS_NAMESPACE=auction-dev
NACOS_GROUP=default
NACOS_DATA_ID=gateway-config.yaml
